{
  "info": {
    "name": "Restaurant Order System API",
    "description": "Complete REST API collection for Restaurant Order System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/health"
          }
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restaurant.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Foods",
      "item": [
        {
          "name": "Get All Foods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/foods?search=biryani&is_veg=false",
              "host": ["{{baseUrl}}"],
              "path": ["foods"],
              "query": [
                { "key": "search", "value": "biryani" },
                { "key": "is_veg", "value": "false" },
                { "key": "category", "value": "3", "disabled": true },
                { "key": "sort", "value": "rating", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Food by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/foods/5"
          }
        },
        {
          "name": "Create Food (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 3,\n  \"name\": \"Mutton Biryani\",\n  \"description\": \"Spicy mutton biryani\",\n  \"price\": 349,\n  \"cooking_time\": 45,\n  \"is_veg\": false\n}"
            },
            "url": "{{baseUrl}}/foods"
          }
        },
        {
          "name": "Update Food (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 329,\n  \"discount_price\": 299\n}"
            },
            "url": "{{baseUrl}}/foods/5"
          }
        },
        {
          "name": "Delete Food (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/foods/99"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Salads\",\n  \"description\": \"Fresh salads\",\n  \"sort_order\": 9\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.orderId) {",
                  "  pm.collectionVariables.set('orderId', json.data.orderId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ajith\",\n  \"phone\": \"9876543210\",\n  \"email\": \"ajith@example.com\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Chennai\",\n  \"pincode\": \"600001\",\n  \"payment\": \"UPI\",\n  \"items\": [\n    {\n      \"foodId\": 5,\n      \"name\": \"Chicken Biryani\",\n      \"qty\": 2,\n      \"price\": 269\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Track Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/track/{{orderId}}"
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Preparing\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Download Invoice",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}/invoice"
          }
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Validate Coupon",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WELCOME10\",\n  \"amount\": 500\n}"
            },
            "url": "{{baseUrl}}/coupons/validate"
          }
        },
        {
          "name": "Get All Coupons (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/coupons"
          }
        },
        {
          "name": "Create Coupon (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SUMMER25\",\n  \"description\": \"25% summer discount\",\n  \"discount_type\": \"percentage\",\n  \"discount_value\": 25,\n  \"min_order_amount\": 400,\n  \"max_discount\": 150,\n  \"valid_from\": \"2026-01-01\",\n  \"valid_until\": \"2026-12-31\"\n}"
            },
            "url": "{{baseUrl}}/coupons"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Export Orders CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/admin/export/orders"
          }
        },
        {
          "name": "Get Offers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/offers"
          }
        }
      ]
    }
  ]
}
